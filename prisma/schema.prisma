model Opportunity {
  id           String            @id @default(cuid())
  artistId     String
  artist       Artist            @relation(fields: [artistId], references: [id], onDelete: Cascade)
  title        String
  organization String?
  type         OpportunityType   @default(OTHER)
  deadline     DateTime?
  prize        String?
  description  String?
  applyUrl     String?
  status       ApplicationStatus @default(DRAFT)
  appliedAt    DateTime?
  notes        String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  @@index([artistId])
}

enum OpportunityType {
  GRANT
  COMPETITION
  LABEL_DEAL
  SYNC_LICENSE
  RESIDENCY
  FESTIVAL
  OTHER
}

enum ApplicationStatus {
  DRAFT
  SUBMITTED
  IN_REVIEW
  ACCEPTED
  REJECTED
  WITHDRAWN
}

model Goal {
  id        String       @id @default(cuid())
  artistId  String
  artist    Artist       @relation(fields: [artistId], references: [id], onDelete: Cascade)
  title     String
  category  GoalCategory @default(GENERAL)
  dueDate   DateTime?
  progress  Int          @default(0)
  archived  Boolean      @default(false)
  tasks     Task[]
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  @@index([artistId])
}

model Task {
  id        String   @id @default(cuid())
  goalId    String
  goal      Goal     @relation(fields: [goalId], references: [id], onDelete: Cascade)
  title     String
  done      Boolean  @default(false)
  dueDate   DateTime?
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@index([goalId])
}

enum GoalCategory {
  RELEASE
  SOCIAL_GROWTH
  PERFORMANCE
  BUSINESS
  LEARNING
  GENERAL
}

model EPK {
  id             String     @id @default(cuid())
  artistId       String     @unique
  artist         Artist     @relation(fields: [artistId], references: [id], onDelete: Cascade)
  slug           String     @unique
  published      Boolean    @default(false)
  bio            String?
  tagline        String?
  pressQuote     String?
  streamingLinks Json?
  photos         EPKPhoto[]
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
}

model EPKPhoto {
  id        String   @id @default(cuid())
  epkId     String
  epk       EPK      @relation(fields: [epkId], references: [id], onDelete: Cascade)
  url       String
  caption   String?
  order     Int      @default(0)
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())
  @@index([epkId])
}

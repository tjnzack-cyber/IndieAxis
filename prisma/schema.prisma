// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Existing enums ───────────────────────────────────────────────────────────

enum Role {
  ARTIST
  MANAGER
  ADMIN
}

enum SubscriptionStatus {
  FREE
  PREMIUM
}

enum MarketingPlanStatus {
  PLANNED
  ACTIVE
  COMPLETED
}

enum ApplicationStatus {
  PENDING
  ACCEPTED
  REJECTED
}

// ─── Phase 1 new enums ────────────────────────────────────────────────────────

enum OpportunityType {
  GRANT
  COMPETITION
  LABEL_DEAL
  SYNC_LICENSE
  RESIDENCY
  FESTIVAL
  OTHER
}

enum OpportunityStatus {
  DRAFT
  SUBMITTED
  IN_REVIEW
  ACCEPTED
  REJECTED
  WITHDRAWN
}

enum GoalCategory {
  RELEASE
  SOCIAL_GROWTH
  PERFORMANCE
  BUSINESS
  LEARNING
  GENERAL
}

// ─── Existing models ──────────────────────────────────────────────────────────

model User {
  id                  String             @id @default(uuid())
  email               String             @unique
  passwordHash        String
  role                Role               @default(ARTIST)
  subscriptionStatus  SubscriptionStatus @default(FREE)
  trialEndsAt         DateTime?
  trialUsed           Boolean            @default(false)
  createdAt           DateTime           @default(now())
  artistProfile       ArtistProfile?
  payments            Payment[]
  passwordResetTokens PasswordResetToken[]
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model ArtistProfile {
  id              String           @id @default(uuid())
  userId          String           @unique
  user            User             @relation(fields: [userId], references: [id])
  name            String
  bio             String?
  genre           String?
  location        String?
  socialLinks     Json?
  profileImageUrl String?
  epks            EPK[]
  marketingPlans  MarketingPlan[]
  gigApplications GigApplication[]
  // ── Phase 1 additions ──
  opportunities   Opportunity[]
  goals           ArtistGoal[]
  // ── Phase 2 additions ──
  releases        Release[]
}

model EPK {
  id          String     @id @default(uuid())
  artistId    String
  artist      ArtistProfile @relation(fields: [artistId], references: [id])
  title       String
  slug        String     @unique
  description String?
  musicLinks  Json?
  videoLinks  Json?
  pressQuotes Json?
  isPublic    Boolean    @default(false)
  // ── Phase 1 addition ──
  photos      EPKPhoto[]
}

model MarketingPlan {
  id       String              @id @default(uuid())
  artistId String
  artist   ArtistProfile       @relation(fields: [artistId], references: [id])
  title    String
  strategy String?
  goals    Json?
  status   MarketingPlanStatus @default(PLANNED)
  tasks    MarketingTask[]
}

model MarketingTask {
  id              String        @id @default(uuid())
  marketingPlanId String
  marketingPlan   MarketingPlan @relation(fields: [marketingPlanId], references: [id])
  title           String
  description     String?
  week            Int?
  isCompleted     Boolean       @default(false)
  order           Int
}

model Gig {
  id            String           @id @default(uuid())
  title         String
  description   String?
  location      String?
  genre         String?
  venueType     String?
  gigDate       DateTime?
  pitchDeadline DateTime?
  applications  GigApplication[]
}

model GigApplication {
  id           String            @id @default(uuid())
  gigId        String
  gig          Gig               @relation(fields: [gigId], references: [id])
  artistId     String
  artist       ArtistProfile     @relation(fields: [artistId], references: [id])
  status       ApplicationStatus @default(PENDING)
  pitchMessage String?
}

model PitchingWindow {
  id          String  @id @default(uuid())
  title       String
  description String?
  month       String
  location    String?
  deadline    String?
  category    String?
}

model Payment {
  id         String   @id @default(uuid())
  amount     Float
  currency   String
  status     String
  reference  String   @unique
  trackingId String?  @unique
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  createdAt  DateTime @default(now())
}

// ─── Phase 1 new models ───────────────────────────────────────────────────────

model Opportunity {
  id           String            @id @default(uuid())
  artistId     String
  artist       ArtistProfile     @relation(fields: [artistId], references: [id], onDelete: Cascade)
  title        String
  organization String?
  type         OpportunityType   @default(OTHER)
  deadline     DateTime?
  prize        String?
  description  String?
  applyUrl     String?
  status       OpportunityStatus @default(DRAFT)
  appliedAt    DateTime?
  notes        String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  @@index([artistId])
}

model ArtistGoal {
  id        String        @id @default(uuid())
  artistId  String
  artist    ArtistProfile @relation(fields: [artistId], references: [id], onDelete: Cascade)
  title     String
  category  GoalCategory  @default(GENERAL)
  dueDate   DateTime?
  progress  Int           @default(0)
  archived  Boolean       @default(false)
  tasks     ArtistTask[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  @@index([artistId])
}

model ArtistTask {
  id        String     @id @default(uuid())
  goalId    String
  goal      ArtistGoal @relation(fields: [goalId], references: [id], onDelete: Cascade)
  title     String
  done      Boolean    @default(false)
  dueDate   DateTime?
  order     Int        @default(0)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  @@index([goalId])
}

model EPKPhoto {
  id        String   @id @default(uuid())
  epkId     String
  epk       EPK      @relation(fields: [epkId], references: [id], onDelete: Cascade)
  url       String
  caption   String?
  order     Int      @default(0)
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())
  @@index([epkId])
}

// ─── Phase 2: Release Planner ─────────────────────────────────────────────────

enum ReleaseType {
  SINGLE
  EP
  ALBUM
  MIXTAPE
  OTHER
}

enum ReleaseStatus {
  IDEA
  IN_PROGRESS
  READY
  RELEASED
}

model Release {
  id          String        @id @default(uuid())
  artistId    String
  artist      ArtistProfile @relation(fields: [artistId], references: [id], onDelete: Cascade)
  title       String
  type        ReleaseType   @default(SINGLE)
  status      ReleaseStatus @default(IDEA)
  releaseDate DateTime?
  coverUrl    String?
  notes       String?
  tasks       ReleaseTask[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  @@index([artistId])
}

model ReleaseTask {
  id        String   @id @default(uuid())
  releaseId String
  release   Release  @relation(fields: [releaseId], references: [id], onDelete: Cascade)
  title     String
  done      Boolean  @default(false)
  dueDate   DateTime?
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@index([releaseId])
}

// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ARTIST
  MANAGER
  ADMIN
}

enum SubscriptionStatus {
  FREE
  PREMIUM
}

enum MarketingPlanStatus {
  PLANNED
  ACTIVE
  COMPLETED
}

enum ApplicationStatus {
  PENDING
  ACCEPTED
  REJECTED
}

model User {
  id                 String             @id @default(uuid())
  email              String             @unique
  passwordHash       String
  role               Role               @default(ARTIST)
  subscriptionStatus SubscriptionStatus @default(FREE)
  trialEndsAt        DateTime?
  trialUsed          Boolean            @default(false)
  createdAt          DateTime           @default(now())
  artistProfile      ArtistProfile?
  payments           Payment[]
  passwordResetTokens PasswordResetToken[]
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model ArtistProfile {
  id              String          @id @default(uuid())
  userId          String          @unique
  user            User            @relation(fields: [userId], references: [id])
  name            String
  bio             String?
  genre           String?
  location        String?
  socialLinks     Json?
  profileImageUrl String?
  epks            EPK[]
  marketingPlans  MarketingPlan[]
  gigApplications GigApplication[]
}

model EPK {
  id              String        @id @default(uuid())
  artistId        String
  artist          ArtistProfile @relation(fields: [artistId], references: [id])
  title           String
  slug            String        @unique
  description     String?
  musicLinks      Json?
  videoLinks      Json?
  pressQuotes     Json?
  isPublic        Boolean       @default(false)
}

model MarketingPlan {
  id        String              @id @default(uuid())
  artistId  String
  artist    ArtistProfile       @relation(fields: [artistId], references: [id])
  title     String
  strategy  String?
  goals     Json?
  status    MarketingPlanStatus @default(PLANNED)
  tasks     MarketingTask[]
}

model MarketingTask {
  id              String        @id @default(uuid())
  marketingPlanId String
  marketingPlan   MarketingPlan @relation(fields: [marketingPlanId], references: [id])
  title           String
  description     String?
  week            Int?
  isCompleted     Boolean       @default(false)
  order           Int
}

model Gig {
  id            String           @id @default(uuid())
  title         String
  description   String?
  location      String?
  genre         String?
  venueType     String?
  gigDate       DateTime?
  pitchDeadline DateTime?
  applications  GigApplication[]
}

model GigApplication {
  id           String            @id @default(uuid())
  gigId        String
  gig          Gig               @relation(fields: [gigId], references: [id])
  artistId     String
  artist       ArtistProfile     @relation(fields: [artistId], references: [id])
  status       ApplicationStatus @default(PENDING)
  pitchMessage String?
}

model PitchingWindow {
  id          String   @id @default(uuid())
  title       String
  description String?
  month       String
  location    String?
  deadline    String?
  category    String? // e.g., 'Festival', 'Playlist', 'Radio'
}

model Payment {
  id         String   @id @default(uuid())
  amount     Float
  currency   String
  status     String   // PENDING, COMPLETED, FAILED
  reference  String   @unique
  trackingId String?  @unique
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  createdAt  DateTime @default(now())
}
